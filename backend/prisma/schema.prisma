generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// App Configs with versioning
model AppConfig {
  id                  String   @id @default(uuid())
  name                String
  slug                String   @unique
  description         String?
  version             String
  config              Json
  is_active           Boolean  @default(true)
  created_by          String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  previous_version_id String?

  @@unique([slug, version])
  @@index([slug, is_active])
  @@index([created_at])
}

// App Data Storage
model AppData {
  id             String   @id @default(uuid())
  config_slug    String
  config_version String
  entity_slug    String
  owner_id       String?
  payload        Json
  version        Int      @default(1)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([config_slug, entity_slug])
  @@index([config_slug, config_version, entity_slug, created_at(sort: Desc)])
  @@index([owner_id])
  @@index([config_slug, entity_slug, owner_id])
  @@index([created_at])
}

// Users
model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  name        String?
  role        String   @default("user")
  avatar      String?
  preferences Json?
  last_login  DateTime?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([email])
  @@index([role])
}

// Event Logs
model EventLog {
  id          String   @id @default(uuid())
  event_type  String
  source      String
  user_id     String?
  config_slug String?
  entity_slug String?
  data        Json?
  severity    String   @default("info")
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  @@index([event_type])
  @@index([created_at(sort: Desc)])
  @@index([config_slug])
  @@index([severity])
}

// CSV Import Records
model CSVImport {
  id             String   @id @default(uuid())
  config_slug    String
  config_version String
  entity_slug    String
  filename       String
  mapping        Json
  type_inference Json?
  status         String   @default("processing")
  total_rows     Int
  success_rows   Int
  error_rows     Int
  errors         Json?
  created_by     String?
  created_at     DateTime @default(now())
  completed_at   DateTime?

  @@index([config_slug])
  @@index([status])
  @@index([created_at])
}

// Config Version History
model ConfigVersion {
  id          String   @id @default(uuid())
  config_slug String
  version     String
  config      Json
  changes     Json?
  created_by  String?
  created_at  DateTime @default(now())

  @@unique([config_slug, version])
  @@index([config_slug, created_at])
}

// User Sessions
model Session {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  expires_at DateTime
  created_at DateTime @default(now())

  @@index([user_id])
  @@index([expires_at])
}

// Notifications
model Notification {
  id         String   @id @default(uuid())
  user_id    String
  type       String
  title      String
  message    String
  data       Json?
  is_read    Boolean  @default(false)
  created_at DateTime @default(now())

  @@index([user_id, is_read])
  @@index([created_at])
}
